{
  "name": "@datasworn-community/build-tools",
  "version": "0.2.0",
  "description": "Build and migration tools for Datasworn source packages.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "datasworn-build": "./dist/cli/datasworn-build.js",
    "datasworn-migrate": "./dist/cli/datasworn-migrate.js"
  },
  "files": [
    "dist",
    "schema-source",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datasworn-community/datasworn.git",
    "directory": "packages/build-tools"
  },
  "author": {
    "name": "rsek",
    "url": "https://github.com/rsek"
  },
  "contributors": [
    {
      "name": "tbsvttr",
      "url": "https://github.com/tbsvttr"
    },
    {
      "name": "Datasworn Community",
      "url": "https://github.com/datasworn-community"
    }
  ],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "0.34.41",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "lodash-es": "^4.18.1",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@datasworn-community/core": "0.2.0"
  },
  "devDependencies": {
    "@datasworn-community/core": "workspace:*",
    "json-schema": "^0.4.0",
    "json-schema-library": "^11.4.1",
    "type-fest": "^5.6.0"
  },
  "bugs": {
    "url": "https://github.com/datasworn-community/datasworn/issues"
  }
}
