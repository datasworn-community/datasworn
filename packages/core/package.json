{
  "name": "@datasworn-community/core",
  "version": "0.2.4",
  "description": "Core Datasworn runtime types, schema artifacts, and ID helpers.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./json/*": "./json/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "json",
    "migration",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datasworn-community/datasworn.git",
    "directory": "packages/core"
  },
  "author": {
    "name": "rsek",
    "url": "https://github.com/rsek"
  },
  "contributors": [
    {
      "name": "tbsvttr",
      "url": "https://github.com/tbsvttr"
    },
    {
      "name": "Datasworn Community",
      "url": "https://github.com/datasworn-community"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/datasworn-community/datasworn/issues"
  }
}
