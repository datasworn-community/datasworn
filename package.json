{
  "name": "@datasworn-community/repo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for Datasworn Community core and build tools packages.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24"
  },
  "workspaces": [
    "packages/core",
    "packages/build-tools"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json && bun ./scripts/writePackageMarkers.ts",
    "check": "tsc --noEmit",
    "lint": "eslint . --quiet",
    "test": "bun test",
    "validate": "bun run check && bun run lint && bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datasworn-community/datasworn.git"
  },
  "author": {
    "name": "rsek",
    "url": "https://github.com/rsek"
  },
  "contributors": [
    {
      "name": "tbsvttr",
      "url": "https://github.com/tbsvttr"
    },
    {
      "name": "Datasworn Community",
      "url": "https://github.com/datasworn-community"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/datasworn-community/datasworn/issues"
  },
  "homepage": "https://github.com/datasworn-community/datasworn#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
